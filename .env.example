# Скопируйте в `.env`. Пароли и DJANGO_SECRET_KEY — в `.env.secrets` (см. `.env.secrets.example`).

# --- PostgreSQL (Biota, источник отметок) ---
# Профиль для быстрого переключения между серверами Biota:
# - BIOTA_DB_PROFILE=MAIN -> BIOTA_DB_MAIN_*
# - BIOTA_DB_PROFILE=ALT  -> BIOTA_DB_ALT_*
# Пусто -> используются обычные BIOTA_DB_*.
BIOTA_DB_PROFILE=

BIOTA_DB_HOST=localhost
BIOTA_DB_PORT=5432
BIOTA_DB_NAME=biota_db
BIOTA_DB_USER=biota_user
BIOTA_DB_CONNECT_TIMEOUT=15

BIOTA_DB_MAIN_HOST=
BIOTA_DB_MAIN_PORT=5432
BIOTA_DB_MAIN_NAME=biota_db
BIOTA_DB_MAIN_USER=biota_user
BIOTA_DB_MAIN_CONNECT_TIMEOUT=15

BIOTA_DB_ALT_HOST=
BIOTA_DB_ALT_PORT=5432
BIOTA_DB_ALT_NAME=biota_db
BIOTA_DB_ALT_USER=biota_user
BIOTA_DB_ALT_CONNECT_TIMEOUT=15

BIOTA_ADMIN_USERNAME=admin

# ZKBioTA / zkbiota: уволенные с is_active=false скрыты по умолчанию (personnel_employee).
# Показать всех: BIOTA_INCLUDE_DISMISSED_EMPLOYEES=1
# Свой критерий: BIOTA_EMPLOYEE_ACTIVE_SQL=and e.status = 1

# --- PostgreSQL (Django default / site_db) ---
# Пустой SITE_DB_HOST → sqlite (db.sqlite3). Задан хост → PostgreSQL.
SITE_DB_HOST=
SITE_DB_PORT=5432
SITE_DB_NAME=site_db
SITE_DB_USER=site_user
SITE_DB_CONNECT_TIMEOUT=15
SITE_DB_CONN_MAX_AGE=60

# --- Django ---
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
