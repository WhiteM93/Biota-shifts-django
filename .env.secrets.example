# Скопируйте в .env.secrets и укажите реальные секреты.
# Файл .env.secrets добавлен в .gitignore и не должен попадать в Git.

# --- PostgreSQL (Biota, источник read-only) ---
BIOTA_DB_PASSWORD=
# Опционально, если используете BIOTA_DB_PROFILE:
BIOTA_DB_MAIN_PASSWORD=
BIOTA_DB_ALT_PASSWORD=

# --- PostgreSQL (Site DB) ---
SITE_DB_PASSWORD=

# --- Вход admin в приложение ---
BIOTA_ADMIN_USERNAME=admin
BIOTA_ADMIN_PASSWORD=
